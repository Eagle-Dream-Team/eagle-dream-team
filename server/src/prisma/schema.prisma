generator client {
  provider     = "prisma-client"
  output       = "./src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  student
  tutor
  staff
}

enum MeetingType {
  in_person
  virtual
}

enum FileType {
  mp4
  mp3
  pdf
  pptx
  recording
}

enum NotificationStatus {
  sent
  failed
}

model User {
  user_id       String   @id @default(uuid())
  email         String   @unique
  password_hash String
  first_name    String
  last_name     String
  role          Role
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  student_allocations UserAllocation[] @relation("StudentAllocations")
  tutor_allocations   UserAllocation[] @relation("TutorAllocations")
  staff_allocations   UserAllocation[] @relation("StaffAllocations")
  sent_messages       Message[]        @relation("SentMessages")
  received_messages   Message[]        @relation("ReceivedMessages")
  meetings_created    Meeting[]
  files_uploaded      File[]
  blog_posts          BlogPost[]
  notifications       Notification[]
}

model UserAllocation {
  allocation_id Int      @id @default(autoincrement())
  student_id    String
  tutor_id      String
  allocated_by  String
  allocated_at  DateTime @default(now())
  is_current    Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  student  User      @relation("StudentAllocations", fields: [student_id], references: [user_id])
  tutor    User      @relation("TutorAllocations", fields: [tutor_id], references: [user_id])
  staff    User      @relation("StaffAllocations", fields: [allocated_by], references: [user_id])
  meetings Meeting[]

  @@map("TutorAllocation")
}

model Message {
  message_id  Int      @id @default(autoincrement())
  sender_id   String
  receiver_id String
  content     String?
  file_id     Int?
  sent_at     DateTime @default(now())
  is_read     Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  sender   User  @relation("SentMessages", fields: [sender_id], references: [user_id])
  receiver User  @relation("ReceivedMessages", fields: [receiver_id], references: [user_id])
  file     File? @relation(fields: [file_id], references: [file_id])
}

model Meeting {
  meeting_id    Int         @id @default(autoincrement())
  allocation_id Int
  created_by    String
  meeting_type  MeetingType
  scheduled_at  DateTime
  location      String?
  link          String?

  notes      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  creator    User           @relation(fields: [created_by], references: [user_id])
  allocation UserAllocation @relation(fields: [allocation_id], references: [allocation_id])
}

model File {
  file_id     Int      @id @default(autoincrement())
  uploaded_by String
  title       String
  file_type   String?
  file_url    String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  uploader User      @relation(fields: [uploaded_by], references: [user_id])
  messages Message[]
}

model BlogPost {
  post_id      Int       @id @default(autoincrement())
  author_id    String
  title        String
  content      String
  is_published Boolean   @default(false)
  published_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  author User @relation(fields: [author_id], references: [user_id])
}

model Notification {
  notification_id Int                @id @default(autoincrement())
  recipient_id    String
  trigger_event   String
  status          NotificationStatus
  sent_at         DateTime?
  created_at      DateTime           @default(now())
  updated_at      DateTime           @updatedAt

  recipient User @relation(fields: [recipient_id], references: [user_id])
}
